# Copy this file to .env and fill in real values. NEVER commit .env.

# Fast Gen AI (image generation) - REQUIRED for AI narrator/character/scene shots
FASTGEN_API_KEY=your_fastgen_key_here
# Optional endpoint overrides:
# FASTGEN_BASE_URL=https://googler.fast-gen.ai
# FASTGEN_STORAGE_URL=https://storage.fast-gen.ai

# Voicer API TTS (ElevenLabs proxy) - REQUIRED when scenario tts = "voicer"
VOICER_API_KEY=your_voicer_key_here
# Optional: backup domain if the main one is blocked in your region
# VOICER_BASE_URL=https://voiceapiru.csv666.ru

# ElevenLabs TTS (optional - direct ElevenLabs, only if tts = "elevenlabs")
ELEVENLABS_API_KEY=

# Stock B-roll (optional - only needed for scene_shot with "source":"stock")
PEXELS_API_KEY=
PIXABAY_API_KEY=

# Voice engine: voicer | edge (free) | elevenlabs | kokoro | chatterbox
VOICE_PROVIDER=voicer
