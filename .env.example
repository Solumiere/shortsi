# Copy this file to .env and fill in real values. NEVER commit .env.

# Fast Gen AI (image generation) - REQUIRED for AI narrator/character/scene shots
FASTGEN_API_KEY=your_fastgen_key_here
# Optional endpoint overrides:
# FASTGEN_BASE_URL=https://googler.fast-gen.ai
# FASTGEN_STORAGE_URL=https://storage.fast-gen.ai

# ElevenLabs TTS (optional - premium voiceover)
ELEVENLABS_API_KEY=

# Stock B-roll (optional - only needed for scene_shot with "source":"stock")
PEXELS_API_KEY=
PIXABAY_API_KEY=

# Voice engine: edge (free) | elevenlabs | kokoro | chatterbox
VOICE_PROVIDER=edge
